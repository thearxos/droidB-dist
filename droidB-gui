    def _load_devinfo(self):
        if self._state() != "device":
            st, nm, sub = self._detect_no_adb()
            if st in ("fastboot", "download", "usb", "recovery", "sideload"):
                L = ["── DETECTED (no adb needed) ──", "  Mode          %s" % sub, "  Name          %s" % nm]
                u = self._usb_android()
                if u:
                    b, manu, prod, ser, vp = u[0]
                    L += ["  Brand         %s" % b, "  Manufacturer  %s" % (manu or "—"),
                          "  Product       %s" % (prod or "—"), "  Serial        %s" % (ser or "—"),
                          "  USB ID        %s" % vp]
                hint = {
                    "download": "Flash firmware from the Flash panel (Samsung Odin).",
                    "fastboot": "Use the Fastboot panel (flash / boot / unlock).",
                    "recovery": "Recovery adb: sideload a ROM, shell, or inject the adb key (Device access).",
                    "sideload": "adb sideload ready — flash an OTA / ROM zip.",
                    "usb":      "Enable USB debugging (Developer options → USB debugging), or use Device access, for full control.",
                }.get(st, "")
                L += ["", "  " + hint]
                self.dev_info.set_text("\n".join(L))
            else:
                self.dev_info.set_text("no device connected.")
            return
        self.dev_info.set_text("reading device…")
        def read():
            # one full getprop dump (parsed locally) + one batched shell call = 2 round-trips
            raw = adb("shell", "getprop", timeout=9) or ""
            P = {}
            for ln in raw.splitlines():
                if ln.startswith("[") and "]: [" in ln:
                    k, v = ln[1:].split("]: [", 1); P[k] = v[:-1] if v.endswith("]") else v
            def p(*keys, d="—"):
                for k in keys:
                    if P.get(k): return P[k]
                return d
            batch = ("echo @BATT; dumpsys battery 2>/dev/null; "
                     "echo @MEM; grep MemTotal /proc/meminfo; "
                     "echo @CPU; grep -c ^processor /proc/cpuinfo; "
                     "echo @KREL; uname -r; echo @KVER; uname -v; "
                     "echo @WM; wm size 2>/dev/null; wm density 2>/dev/null; "
                     "echo @SEL; getenforce 2>/dev/null; "
                     "echo @ROOT; (command -v su || echo none); "
                     "echo @UP; cat /proc/uptime; "
                     "echo @IP; ip -o -4 addr 2>/dev/null; "
                     "echo @DF; df -h /data 2>/dev/null | tail -1; "
                     "echo @END")
            out = adb("shell", batch, timeout=12) or ""
            sec, S = None, {}
            for ln in out.splitlines():
                s = ln.strip()
                if s.startswith("@"): sec = s; S[sec] = []
                elif sec: S[sec].append(ln)
            def sect(name): return "\n".join(S.get(name, []))
            def bf(name):
                for l in sect("@BATT").splitlines():
                    if l.strip().startswith(name + ":"): return l.split(":", 1)[1].strip()
                return "?"
            mem = sect("@MEM"); memgb = "%.1f GB" % (int(mem.split()[1]) / 1048576) if mem.split() else "?"
            cores = sect("@CPU").strip() or "?"
            wm = sect("@WM"); res = dens = "?"
            for l in wm.splitlines():
                if "size:" in l.lower(): res = l.split(":")[-1].strip()
                if "density:" in l.lower(): dens = l.split(":")[-1].strip()
            up = sect("@UP").split(".")[0].strip()
            try: up = "%dh %dm" % (int(up)//3600, (int(up)%3600)//60)
            except Exception: pass
            ipaddr = "—"
            for l in sect("@IP").splitlines():
                if any(i in l for i in ("wlan", "rmnet", "eth")) and "inet" in l:
                    for tok in l.split():
                        if "." in tok and "/" in tok: ipaddr = tok.split("/")[0]; break
                    if ipaddr != "—": break
            root_bin = sect("@ROOT").strip()
            rooted = "yes (%s)" % root_bin if root_bin and root_bin != "none" else "no"
            df = sect("@DF").split()
            store = "%s used / %s (%s)" % (df[2], df[1], df[4]) if len(df) >= 5 else "—"
            brand = p("ro.product.brand", "ro.product.manufacturer", d="")
            samsung = "samsung" in brand.lower()

            L = []
            def sec_hdr(t): L.append(""); L.append("── %s ──" % t)
            def kv(k, v): L.append("  %-13s %s" % (k, v))

            sec_hdr("IDENTITY")
            kv("Model", p("ro.product.model"))
            kv("Marketing", p("ro.product.vendor.marketname", "ro.config.marketing_name", "ro.product.marketname"))
            kv("Brand", "%s · %s" % (p("ro.product.brand"), p("ro.product.manufacturer")))
            kv("Codename", p("ro.product.device", "ro.product.vendor.device"))
            kv("Serial", p("ro.serialno", "ro.boot.serialno"))
            if samsung:
                sec_hdr("SAMSUNG")
                kv("Bootloader", p("ro.bootloader"))
                kv("CSC", "%s / %s" % (p("ro.csc.sales_code", "ril.sales_code"), p("ro.csc.country_code", "ro.boot.carrierid")))
                kv("Carrier ID", p("ro.boot.carrierid", "ro.boot.carrier"))
                kv("OEM unlock", p("sys.oem_unlock_allowed", "ro.oem_unlock_supported"))
                kv("Warranty bit", p("ro.boot.warranty_bit", "ro.warranty_bit"))
                kv("Knox", p("ro.boot.knox.kap.enabled", "ro.config.knox"))
            sec_hdr("BUILD")
            kv("Android", "%s  (API %s)" % (p("ro.build.version.release"), p("ro.build.version.sdk")))
            kv("Patch", p("ro.build.version.security_patch"))
            kv("Build ID", p("ro.build.display.id", "ro.build.id"))
            kv("Build date", p("ro.build.date"))
            kv("Baseband", p("gsm.version.baseband", "ro.baseband"))
            kv("Kernel", sect("@KREL").strip() or "—")
            kv("Treble/GSI", p("ro.treble.enabled"))
            sec_hdr("HARDWARE")
            kv("SoC", "%s %s" % (p("ro.soc.manufacturer", d=""), p("ro.soc.model", "ro.board.platform", "ro.hardware")).strip())
            kv("ABI", "%s  [%s]" % (p("ro.product.cpu.abi"), p("ro.product.cpu.abilist")))
            kv("Cores", cores)
            kv("RAM", memgb)
            kv("Screen", "%s @ %s" % (res, dens))
            sec_hdr("BATTERY")
            kv("Level", "%s%%  (%s)" % (bf("level"), bf("status")))
            kv("Health", bf("health"))
            kv("Temp", "%s" % bf("temperature"))
            sec_hdr("STORAGE / STATE")
            kv("Data", store)
            kv("Bootloader", "%s  (vbstate %s)" % (p("ro.boot.flash.locked", "ro.boot.locked"), p("ro.boot.verifiedbootstate")))
            kv("Root", rooted)
            kv("SELinux", sect("@SEL").strip() or "—")
            kv("Encryption", "%s / %s" % (p("ro.crypto.state"), p("ro.crypto.type")))
            kv("Uptime", up)
            kv("IP", ipaddr)
            return "\n".join(L).lstrip("\n")
        self._run_async(read, self.dev_info.set_text)

    def _reboot(self, *_):
        if self._state() not in ("device", "recovery", "sideload"):
            self._msg("No device", "No device connected."); return
        mode = self.reboot_to.get_active_text()
        self._run_async(lambda: adb("reboot", "" if mode == "system" else mode))

    def _enable_debug(self, *_):
        if not self._confirm("Enable USB debugging (override)",
                             "Turn USB debugging ON for a device that shipped with it off.\n\n"
                             "This needs a debugging-independent way in — a recovery adb shell (TWRP) or a rooted "
                             "shell. It trusts this PC, sets adb_enabled=1, and enables the adb interface; then you reboot.\n\n"
                             "A fully locked device with only stock recovery and debugging off cannot be overridden "
                             "(that is Android's security boundary). droidB-adb will detect your case and tell you."):
            return
        self._termrun("enable USB debugging", "droidB-adb detect; echo; droidB-adb enable-debug")

    def _locked_out(self, *_):
        # forgot/scrambled the PIN: honest recovery options (encrypted /data can't be bypassed)
        self._termrun("locked out - recovery options", "droidB-adb recover")

    def _p_apps(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.pack_start(self._hdr("Apps", "installed packages - uninstall, disable, clear, install"), False, False, 0)
