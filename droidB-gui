    # ---- helpers ----
    def _state(self):
        return adb("get-state", timeout=4) or "offline"

    def _refresh(self):
        # poll off the UI thread so a slow/offline device never freezes the window; the guard
        # keeps a slow poll from stacking up when the 1s tick fires again before it finishes
        if self._polling: return True
        self._polling = True
        def work():
            try:
                st = self._state()
                if st == "device":
                    model = adb("shell", "getprop", "ro.product.model", timeout=4) or "device"
                    rel = adb("shell", "getprop", "ro.build.version.release", timeout=4)
                    GLib.idle_add(self._apply_state, "device", model, rel)
                else:
                    stt, nm, sub = self._detect_no_adb()   # fastboot / download / raw-USB, no debugging needed
                    GLib.idle_add(self._apply_state, stt, nm, sub)
            finally:
                self._polling = False
        threading.Thread(target=work, daemon=True).start()
        return True

    def _apply_state(self, st, name, sub):
        c = self.dev.get_style_context(); c.remove_class("on"); c.remove_class("off")
        if st == "device":
            self.dev.set_text("● %s · Android %s" % (name, sub)); c.add_class("on")
        elif st in ("fastboot", "download", "usb", "recovery", "sideload"):
            self.dev.set_text("◐ %s · %s" % (name, sub)); c.add_class("on")   # seen without adb
        else:
            self.dev.set_text("○ no device · enable USB debugging"); c.add_class("off")
        # refresh the Device page on ANY state change so it never shows stale info: clears when a
        # device is unplugged, updates on connect / mode change (fixes lingering "Download mode")
        if st != self._prev_state:
            self._prev_state = st
            try: self._load_devinfo()
            except Exception: pass
        return False

    # Android USB vendor IDs - seen via raw USB enumeration even with USB debugging OFF
    _ANDROID_VID = {
        "04e8": "Samsung", "18d1": "Google", "22b8": "Motorola", "2717": "Xiaomi", "22d9": "Oppo",
        "2a70": "OnePlus", "12d1": "Huawei", "0bb4": "HTC", "1004": "LG", "19d2": "ZTE",
        "0fce": "Sony", "2a45": "Meizu", "05c6": "Qualcomm EDL", "0e8d": "MediaTek",
        "0489": "Fairphone", "2916": "Yota", "1bbb": "Alcatel", "0e79": "Archos",
    }
    def _usb_android(self):
        import glob
        found = []
        for d in glob.glob("/sys/bus/usb/devices/*/"):
            def rd(f):
                try: return open(d + f).read().strip()
                except Exception: return ""
            vid = rd("idVendor").lower()
            if vid not in self._ANDROID_VID: continue
            found.append((self._ANDROID_VID[vid], rd("manufacturer"), rd("product"), rd("serial"), vid + ":" + rd("idProduct")))
        return found

    def _detect_no_adb(self):
        # no normal adb (USB debugging off / not authorized) - try the paths that need no toggle.
        # recovery/sideload adb is enabled BY the recovery, not the OS debugging switch.
        st = adb("get-state", timeout=3) or ""
        if "recovery" in st: return ("recovery", "device", "recovery adb — sideload / shell / key-inject")
        if "sideload" in st: return ("sideload", "device", "adb sideload ready")
        fb = fastboot("devices", timeout=4) or ""
        if fb.strip() and "fastboot" in fb:
            return ("fastboot", (fb.split() or ["device"])[0], "fastboot / bootloader")
        for tool in ("odin4", "heimdall"):
            if have(tool):
                try:
                    r = subprocess.run([tool, "-l" if tool == "odin4" else "detect"],
                                       capture_output=True, text=True, timeout=4).stdout or ""
                    if "/dev/" in r or "detected" in r.lower():
                        return ("download", "Samsung", "Download mode (%s)" % tool)
                except Exception: pass
        u = self._usb_android()
        if u:
            brand, manu, prod, ser, vidpid = u[0]
            name = (prod or brand or "Android").strip()
            return ("usb", name, "%s · connected, USB debugging off (%s)" % (brand, vidpid))
        return ("offline", "", "")

    def _need_device(self):
        if self._state() != "device":
            self._msg("No device", "Connect a device with USB debugging enabled, then accept the prompt on the phone.")
            return False
        return True

    def _msg(self, title, body):
        m = Gtk.MessageDialog(transient_for=self, modal=True, message_type=Gtk.MessageType.INFO,
