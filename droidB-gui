    def _pull_boot(self):
        if not self._need_device(): return
        out = os.path.join(self._outdir(), "boot.img")
        self.mod_out.set_text("pulling boot (needs root)…")
        def run():
            adb("shell", "su", "-c", "dd if=/dev/block/by-name/boot of=/sdcard/droidB-boot.img", timeout=40)
            adb("pull", "/sdcard/droidB-boot.img", out, timeout=60); adb("shell", "rm", "/sdcard/droidB-boot.img")
            return ("saved " + out) if os.path.exists(out) else "could not pull boot (root needed - or extract boot.img from firmware)"
        self._run_async(run, self.mod_out.set_text)

    def _magisk_patch(self, *_):
        boot = self._pick("boot.img to patch with Magisk")
        if not boot: return
        self.mod_out.set_text("patching with Magisk → %s_magisk.img (watch the terminal)" % os.path.splitext(boot)[0])
        self._termrun("Magisk patch", "droidB-mod magisk-patch %s" % shlex.quote(boot))

    def _fb_flash_part(self, part):
        img = self._pick("%s image (fastboot)" % part)
        if not img: return
        if not self._confirm("Flash %s" % part, "fastboot flash %s '%s'? Can brick." % (part, os.path.basename(img))): return
        self._run_async(lambda: fastboot("flash", part, img, timeout=300), lambda r: self.mod_out.set_text(r or "flash done"))

    def _boot_img(self, *_):
        img = self._pick("image to boot temporarily")
        if not img: return
        self._run_async(lambda: fastboot("boot", img, timeout=120), lambda r: self.mod_out.set_text(r or "booting…"))

    def _flash_gsi(self, *_):
        img = self._pick("GSI system image (.img)")
        if not img: return
        if not self._confirm("Flash GSI", "Flash this GSI to 'system' and wipe userdata? The device must be unlocked + in fastboot."):
            return
        def run():
            fastboot("--disable-verity", "--disable-verification", "flash", "system", img, timeout=400)
            fastboot("-w", timeout=60); return "GSI flashed + data wiped - reboot the device"
        self.mod_out.set_text("flashing GSI…"); self._run_async(run, self.mod_out.set_text)

    def _sideload(self, *_):
        z = self._pick("ROM .zip to sideload (device: recovery → Apply update → from ADB)")
        if not z: return
        self._termrun("sideload ROM", "adb sideload %s" % shlex.quote(z))

    def _fb_update(self, *_):
        z = self._pick("fastboot update package (.zip)")
        if not z: return
        if not self._confirm("Fastboot update", "fastboot update '%s'? Can brick." % os.path.basename(z)): return
        self._termrun("fastboot update", "fastboot update %s" % shlex.quote(z))

    def _extract(self, kind):
        f = self._pick("payload.bin or OTA .zip" if kind == "payload" else "super.img")
        if not f: return
        out = os.path.join(self._outdir(), kind)
        self.mod_out.set_text("extracting → %s (watch the terminal)" % out)
        self._termrun(kind + " extract", "droidB-mod %s %s %s" % (kind, shlex.quote(f), shlex.quote(out)))

    # ---- Debloat (mass debloat) ----
    def _bloatset(self):
        # curated exact-match OEM/Samsung bloat list (samsung-bloat.txt), loaded once + cached
        if not hasattr(self, "_bloat_exact"):
            self._bloat_exact = set()
            for p in ("/usr/share/droidB/samsung-bloat.txt",
                      os.path.expanduser("~/.local/share/droidB/samsung-bloat.txt")):
                try:
                    with open(p) as f:
                        self._bloat_exact = {l.strip() for l in f if l.strip() and not l.startswith("#")}
                    break
                except Exception:
                    pass
        return self._bloat_exact

    def _is_bloat(self, pkg):
        if pkg in self._bloatset(): return True
        pats = ("com.facebook.", "com.google.android.youtube", "com.google.android.apps.tachyon",
                "com.google.android.apps.docs", "com.google.android.apps.maps", "com.google.android.gm",
                "com.google.android.videos", "com.google.android.apps.music", "com.google.android.apps.photos",
                "com.samsung.", "com.sec.android.app.samsungapps", "com.samsung.android.bixby",
                "com.miui.", "com.xiaomi.", "com.mi.", "com.microsoft.", "com.amazon.", "com.netflix.",
                "com.spotify.", "com.linkedin.", "com.twitter.", "com.instagram.", "com.snapchat.",
                "com.zhiliaoapp.musically", "com.hicloud.", "com.huawei.appmarket", "com.android.chrome")
        return any(pkg.startswith(b) or b in pkg for b in pats)

    def _p_debloat(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.pack_start(self._hdr("Debloat", "find and remove OEM / carrier bloatware - uninstall (keeps the APK) or disable"), False, False, 0)
        top = Gtk.Box(spacing=8)
        self.bl_filter = Gtk.SearchEntry(); self.bl_filter.set_placeholder_text("filter packages…")
        self.bl_filter.connect("search-changed", lambda *_: self.bl_filt.refilter()); top.pack_start(self.bl_filter, True, True, 0)
        self.bl_only = Gtk.CheckButton(label="likely bloat only"); self.bl_only.set_active(True)
        self.bl_only.connect("toggled", lambda *_: self._debloat_load()); top.pack_start(self.bl_only, False, False, 0)
        top.pack_start(self._act("Scan", lambda *_: self._debloat_load()), False, False, 0)
        box.pack_start(top, False, False, 0)
        self.bl_store = Gtk.ListStore(str)
        self.bl_filt = self.bl_store.filter_new()
        self.bl_filt.set_visible_func(lambda m, it, _: self.bl_filter.get_text().lower() in (m[it][0] or "").lower())
        self.bl_view = Gtk.TreeView(model=self.bl_filt); self.bl_view.get_selection().set_mode(Gtk.SelectionMode.MULTIPLE)
        self.bl_view.append_column(Gtk.TreeViewColumn("Package", Gtk.CellRendererText(), text=0))
        box.pack_start(self._scroller(self.bl_view), True, True, 0)
        bar = Gtk.Box(spacing=8)
        bar.pack_start(self._act("Uninstall selected", lambda *_: self._debloat_act("uninstall"), danger=True), False, False, 0)
        bar.pack_start(self._act("Disable selected", lambda *_: self._debloat_act("disable")), False, False, 0)
        bar.pack_start(self._act("Remove ALL likely bloat", self._debloat_all, danger=True), False, False, 0)
        box.pack_start(bar, False, False, 0)
        self.bl_status = Gtk.Label(label="scan a connected device"); self.bl_status.set_xalign(0); self.bl_status.get_style_context().add_class("sub")
        box.pack_start(self.bl_status, False, False, 0)
        GLib.timeout_add(1000, lambda: (self._debloat_load(), False)[1])
        return box

    def _debloat_load(self):
        if self._state() != "device": return
        self.bl_store.clear()
        def read():
            out = adb("shell", "pm", "list", "packages", "-3", timeout=15)   # third-party = removable
            pkgs = sorted(l.replace("package:", "").strip() for l in out.splitlines() if l.strip())
            return [p for p in pkgs if self._is_bloat(p)] if self.bl_only.get_active() else pkgs
        def fill(pkgs):
            for p in pkgs: self.bl_store.append([p])
            self.bl_status.set_text("%d package(s)%s" % (len(pkgs), " matching known bloat" if self.bl_only.get_active() else ""))
        self._run_async(read, fill)

    def _debloat_sel(self):
        m, paths = self.bl_view.get_selection().get_selected_rows(); return [m[p][0] for p in paths]

    def _debloat_act(self, what):
        sel = self._debloat_sel()
        if not sel: self._msg("Select apps", "Pick packages to " + what + "."); return
        if not self._confirm("%s %d package(s)" % (what.title(), len(sel)), "This affects the device immediately."): return
        def run():
            for p in sel:
                if what == "uninstall": adb("shell", "pm", "uninstall", "-k", "--user", "0", p)
                else: adb("shell", "pm", "disable-user", "--user", "0", p)
            GLib.idle_add(self._debloat_load); GLib.idle_add(self.bl_status.set_text, "%sed %d" % (what, len(sel)))
        self._run_async(run)

    def _debloat_all(self, *_):
        if not self._need_device(): return
        def read():
            out = adb("shell", "pm", "list", "packages", "-3", timeout=15)
            return [l.replace("package:", "").strip() for l in out.splitlines() if l.strip() and self._is_bloat(l.replace("package:", "").strip())]
        def ask(pkgs):
            if not pkgs: self._msg("Debloat", "No known bloat found."); return
            if not self._confirm("Remove %d bloat apps" % len(pkgs), "\n".join(pkgs[:15]) + ("\n…" if len(pkgs) > 15 else "")): return
            def run():
                for p in pkgs: adb("shell", "pm", "uninstall", "-k", "--user", "0", p)
                GLib.idle_add(self._debloat_load); GLib.idle_add(self.bl_status.set_text, "removed %d bloat apps" % len(pkgs))
            self._run_async(run)
        self._run_async(read, ask)

