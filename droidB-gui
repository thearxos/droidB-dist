    def _screenshot(self, *_):
        if not self._need_device(): return
        path = os.path.join(self._outdir(), "shot-%d.png" % int(time.time()))
        def run():
            try:
                with open(path, "wb") as f:
                    subprocess.run(["adb", "exec-out", "screencap", "-p"], stdout=f, timeout=20)
                return path
            except Exception as e: return str(e)
        def done(p):
            self.scr_out.set_text("saved " + p)
            if os.path.exists(p): self.scr_img.set_from_file(p)
        self._run_async(run, done)

    def _screenrecord(self, *_):
        if not self._need_device(): return
        rp = "/sdcard/droidB-rec.mp4"; lp = os.path.join(self._outdir(), "rec-%d.mp4" % int(time.time()))
        self.scr_out.set_text("recording 10s…")
        def run():
            adb("shell", "screenrecord", "--time-limit", "10", rp, timeout=20)
            adb("pull", rp, lp, timeout=60); adb("shell", "rm", rp)
            return "saved " + lp
        self._run_async(run, self.scr_out.set_text)

    def _mirror(self, *_):
        if not self._need_device(): return
        if not self._ensure_scrcpy(): return
        subprocess.Popen(["scrcpy"])

    def _ensure_scrcpy(self):
        if have("scrcpy"): return True
        if self._confirm("scrcpy not installed", "Install scrcpy now (arx install scrcpy)?"):
            subprocess.Popen(["xfce4-terminal", "-x", "bash", "-lc", "arx install scrcpy; read -rp 'enter…'"])
        return False

    def _mirror_rescue(self, *_):
        # the dead-display savior: mirror the broken screen to the PC, keep the phone awake,
        # turn its own (broken) panel off, and drive it with the PC mouse/keyboard
        if not self._ensure_scrcpy(): return
        subprocess.Popen(["scrcpy", "--stay-awake", "--turn-screen-off", "--show-touches"])

    def _mirror_otg(self, *_):
        # HID keyboard+mouse over USB - works even at the lock screen, no adb mirror needed
        if not self._ensure_scrcpy(): return
        subprocess.Popen(["xfce4-terminal", "--title", "droidB · scrcpy OTG (HID)", "-x", "bash", "-lc",
                          "scrcpy --otg; echo; read -rp 'enter to close…'"])

    def _blind_unlock(self, *_):
        pin = self._prompt("Blind unlock", "Device PIN/password - sent over adb, no screen needed (PIN/password, not pattern)")
        if not pin: return
        cmd = ("adb shell input keyevent 224; sleep 0.5; "            # wake
               "adb shell input swipe 540 1600 540 400; sleep 0.5; "  # swipe up to the keyguard entry
               "adb shell input text %s; sleep 0.3; "                 # type the PIN
               "adb shell input keyevent 66; echo 'unlock sent'") % shlex.quote(pin)
        self._termrun("blind unlock", cmd)

