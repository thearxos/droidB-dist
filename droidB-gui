        if not pkg: return
        self._termrun("app data", "adb shell su -c 'tar -czf /sdcard/%s.tgz /data/data/%s' && adb pull /sdcard/%s.tgz %s" % (pkg, pkg, pkg, self._bkdir()))

    def _bk_rescue(self, *_):
        if self._state() not in ("device", "recovery"):
            self._msg("No device", "Connect the device with USB debugging, or boot recovery (recovery adb needs no toggle), then retry."); return
        if not self._confirm("Emergency backup — do this before flashing",
                             "Pull contacts, call logs, SMS, media, the app list and app data to ~/droidB-rescue?\n\n"
                             "The media pull can take a while; you may get an on-screen backup prompt for app data (leave the password blank)."):
            return
        self._termrun("emergency rescue backup", "droidB-rescue")

    def _bk_authorize(self, *_):
        if not self._confirm("Authorize this PC (ADB key)",
                             "Push this PC's ADB key onto the device so the shell trusts it with NO on-screen prompt "
                             "(the way back in when the screen is cracked or black)?\n\nNeeds root or a recovery adb shell with /data mounted."):
            return
        self._termrun("authorize adb key", "droidB-rescue --authorize")

    # ---- Frida ----
    def _p_frida(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.pack_start(self._hdr("Frida", "dynamic instrumentation - server, processes, attach / spawn"), False, False, 0)
        r1 = Gtk.Box(spacing=8)
        r1.pack_start(self._act("Install server (auto-arch)", self._frida_install), False, False, 0)
        r1.pack_start(self._act("Start server", lambda *_: self._termrun("frida-server", "adb shell su -c '/data/local/tmp/frida-server &' 2>/dev/null || adb shell '/data/local/tmp/frida-server &'; echo started")), False, False, 0)
        r1.pack_start(self._act("Stop server", lambda *_: self._run_async(lambda: adb("shell", "pkill", "-f", "frida-server") or "stopped", self.fr_out.set_text)), False, False, 0)
        box.pack_start(r1, False, False, 0)
        r2 = Gtk.Box(spacing=8)
        r2.pack_start(self._act("List processes", lambda *_: self._termrun("frida-ps", "frida-ps -Ua")), False, False, 0)
        r2.pack_start(self._act("Attach to app…", self._frida_attach), False, False, 0)
        r2.pack_start(self._act("Spawn app…", self._frida_spawn), False, False, 0)
        box.pack_start(r2, False, False, 0)
        self.fr_out = Gtk.Label(label="needs frida-tools on the host (arx install python-frida-tools) + frida-server on the device"); self.fr_out.set_xalign(0)
        self.fr_out.get_style_context().add_class("sub"); self.fr_out.set_line_wrap(True)
        box.pack_start(self.fr_out, False, False, 0)
        return box

    def _frida_install(self, *_):
        if not self._need_device(): return
        cmd = ("set -e; a=$(adb shell getprop ro.product.cpu.abi | tr -d '\\r'); "
               "case $a in arm64*) fa=arm64;; armeabi*) fa=arm;; x86_64) fa=x86_64;; x86) fa=x86;; *) fa=arm64;; esac; "
               "v=$(frida --version 2>/dev/null || echo 16.5.9); echo \"device $fa, frida $v\"; "
               "u=https://github.com/frida/frida/releases/download/$v/frida-server-$v-android-$fa.xz; "
               "curl -fsSL $u -o /tmp/fs.xz && unxz -f /tmp/fs.xz && adb push /tmp/fs /data/local/tmp/frida-server "
               "&& adb shell chmod 755 /data/local/tmp/frida-server && echo 'frida-server installed'")
        self._termrun("install frida-server", cmd)

    def _frida_attach(self, *_):
        app = self._prompt("Attach", "app package / name")
        if app: self._termrun("frida attach", "frida -U %s" % shlex.quote(app))

    def _frida_spawn(self, *_):
        app = self._prompt("Spawn", "app package")
        if app: self._termrun("frida spawn", "frida -U -f %s --no-pause" % shlex.quote(app))

    # ---- Security (MITM / cert / capture) ----
    def _p_security(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.pack_start(self._hdr("Security", "MITM proxy, CA certificate, packet capture"), False, False, 0)
        r1 = Gtk.Box(spacing=8)
        r1.pack_start(Gtk.Label(label="proxy host:port"), False, False, 0)
        self.sec_proxy = Gtk.Entry(); self.sec_proxy.set_placeholder_text("192.168.1.10:8080"); self.sec_proxy.set_hexpand(True)
        r1.pack_start(self.sec_proxy, True, True, 0)
        r1.pack_start(self._act("Set proxy", self._sec_setproxy), False, False, 0)
        r1.pack_start(self._act("Clear", lambda *_: self._run_async(lambda: adb("shell", "settings", "put", "global", "http_proxy", ":0") or "proxy cleared", self.sec_out.set_text)), False, False, 0)
        box.pack_start(r1, False, False, 0)
        r2 = Gtk.Box(spacing=8)
        r2.pack_start(self._act("Install CA cert…", self._sec_cert), False, False, 0)
        r2.pack_start(self._act("Start capture (tcpdump)", lambda *_: self._sec_capture(True)), False, False, 0)
        r2.pack_start(self._act("Stop + pull pcap", lambda *_: self._sec_capture(False)), False, False, 0)
        box.pack_start(r2, False, False, 0)
        self.sec_out = Gtk.Label(label="point the proxy at your Burp / mitmproxy listener, then install the CA cert to intercept HTTPS"); self.sec_out.set_xalign(0)
        self.sec_out.get_style_context().add_class("sub"); self.sec_out.set_line_wrap(True)
        box.pack_start(self.sec_out, False, False, 0)
        return box

    def _sec_setproxy(self, *_):
        if not self._need_device(): return
        hp = self.sec_proxy.get_text().strip()
        if not hp: self._msg("host:port?", "Enter your proxy as host:port."); return
        self._run_async(lambda: adb("shell", "settings", "put", "global", "http_proxy", hp) or ("proxy set to " + hp), self.sec_out.set_text)

    def _sec_cert(self, *_):
        if not self._need_device(): return
        f = self._pick("CA certificate (.pem / .crt / .cer)")
        if not f: return
        self._termrun("install CA cert", "adb push %s /sdcard/arxos-ca.crt && echo 'Pushed to /sdcard/arxos-ca.crt. On the device: Settings > Security > Encryption & credentials > Install a certificate > CA certificate.'" % shlex.quote(f))

    def _sec_capture(self, start):
        if not self._need_device(): return
        if start:
            self.sec_out.set_text("capturing… (needs tcpdump on the device / root)")
            self._termrun("tcpdump", "adb shell su -c 'tcpdump -i any -w /sdcard/arxos-cap.pcap' 2>/dev/null || adb shell tcpdump -i any -w /sdcard/arxos-cap.pcap")
        else:
            d = self._outdir()
            self._run_async(lambda: (adb("shell", "pkill", "tcpdump"), adb("pull", "/sdcard/arxos-cap.pcap", d, timeout=60), "pcap pulled to " + d)[-1], self.sec_out.set_text)


