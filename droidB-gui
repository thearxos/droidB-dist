    def _vendor_tool(self, kind):
        # returns the command base, installing the tool on demand via a terminal
        tool = "mtk" if kind == "mtk" else "heimdall"
        pkg = "mtkclient" if kind == "mtk" else "heimdall"
        if not have(tool):
            if self._confirm(tool + " not installed", "Install %s now?" % pkg):
                subprocess.Popen(["xfce4-terminal", "-x", "bash", "-lc", "arx install %s; read -rp 'enter…'" % pkg])
            return None
        return tool

    def _vendor(self, kind, args):
        tool = self._vendor_tool(kind)
        if not tool: return
        self.fl_out.set_text("running %s %s … (watch the terminal)" % (tool, args))
        # vendor flashing is long + interactive -> run in a terminal so the user sees prompts
        subprocess.Popen(["xfce4-terminal", "--title", "droidB · " + tool, "-x", "bash", "-lc",
                          "%s %s; echo; read -rp 'done - enter to close…'" % (tool, args)])

    def _mtk_part_op(self, op):
        if not self._vendor_tool("mtk"): return
        part = self.mtk_part.get_text().strip()
        if not part: self._msg("Partition?", "Enter a partition name (e.g. boot)."); return
        if op == "e":
            if self._confirm("Erase " + part, "Erase the %s partition?" % part):
                self._vendor("mtk", "e " + shlex.quote(part))
            return
        d = Gtk.FileChooserDialog(title=("Save to" if op == "r" else "Image to write"), parent=self,
                                  action=(Gtk.FileChooserAction.SAVE if op == "r" else Gtk.FileChooserAction.OPEN))
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "OK", Gtk.ResponseType.OK)
        if op == "r": d.set_current_folder(self._outdir()); d.set_current_name(part + ".img")
        ok = d.run() == Gtk.ResponseType.OK; f = d.get_filename(); d.destroy()
        if not ok or not f: return
        if op == "w" and not self._confirm("Flash " + part, "Write %s to %s? Can brick." % (os.path.basename(f), part)): return
        self._vendor("mtk", "%s %s %s" % (op, shlex.quote(part), shlex.quote(f)))

    def _mtk_flash_all(self, *_):
        if not self._vendor_tool("mtk"): return
        d = Gtk.FileChooserDialog(title="Folder of partition images", parent=self, action=Gtk.FileChooserAction.SELECT_FOLDER)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Flash all", Gtk.ResponseType.OK)
        if d.run() != Gtk.ResponseType.OK: d.destroy(); return
        folder = d.get_filename(); d.destroy()
        if self._confirm("Flash all", "Write every image in the folder to its partition? Can brick."):
            self._vendor("mtk", "wl " + shlex.quote(folder))

    def _mtk_lock(self, which):
        if not self._vendor_tool("mtk"): return
        if self._confirm("%s bootloader" % which.title(), "%s the bootloader via seccfg? Unlock wipes data." % which.title()):
            self._vendor("mtk", "da seccfg " + which)

    def _sam_pick(self, slot):
        d = Gtk.FileChooserDialog(title=slot + " file", parent=self, action=Gtk.FileChooserAction.OPEN)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Select", Gtk.ResponseType.OK)
        if d.run() == Gtk.ResponseType.OK: self.sam[slot].set_text(d.get_filename())
        d.destroy()

    def _sam_flash(self, *_):
        files = [self.sam[s].get_text().strip() for s in ("BL", "AP", "CP", "CSC", "USERDATA") if self.sam[s].get_text().strip()]
        if not files:
            self._msg("No firmware", "Fill at least one Odin slot (BL / AP / CP / CSC)."); return
        backend = "odin4" if self.sam_odin.get_active() else "heimdall"
        if not have(backend):
            if self._confirm("%s not installed" % backend, "Install %s now?" % backend):
                subprocess.Popen(["xfce4-terminal", "-x", "bash", "-lc", "arx install %s; read -rp 'enter…'" % backend])
            return
        if not self._confirm("Flash Samsung firmware",
                             "Device must be in Download mode. Wrong firmware or Nand Erase can wipe data or brick. Continue?"):
            return
        args = ["droidB-samsung", "--backend", backend]
        if self.sam_reboot.get_active(): args += ["--reboot"]
        if self.sam_keep.get_active():   args += ["--preserve-data"]
        if self.sam_nand.get_active():   args += ["--nand-erase", "--force"]
        args += files
        cmd = " ".join(shlex.quote(a) for a in args)
        subprocess.Popen(["xfce4-terminal", "--title", "droidB · Samsung flash", "-x", "bash", "-lc",
                          "%s; echo; read -rp 'done - enter to close…'" % cmd])

    # ---- Root / ROM ----
    def _pick(self, title, save=False, name=None):
        act = Gtk.FileChooserAction.SAVE if save else Gtk.FileChooserAction.OPEN
        d = Gtk.FileChooserDialog(title=title, parent=self, action=act)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "OK", Gtk.ResponseType.OK)
        if name: d.set_current_folder(self._outdir()); d.set_current_name(name)
        f = d.get_filename() if d.run() == Gtk.ResponseType.OK else None
        d.destroy(); return f

    def _termrun(self, title, cmd):
        subprocess.Popen(["xfce4-terminal", "--title", "droidB · " + title, "-x", "bash", "-lc",
                          "%s; echo; read -rp 'done - enter to close…'" % cmd])

