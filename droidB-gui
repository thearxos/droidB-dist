    def _human(self, n):
        try: n = int(n)
        except Exception: return n
        for u in ("B", "K", "M", "G", "T"):
            if n < 1024: return ("%d%s" % (n, u)) if u == "B" else ("%.1f%s" % (n, u))
            n /= 1024.0
        return "%.1fP" % n

    def _fb_go(self, path):
        if not path.endswith("/"): path += "/"
        self.f_path.set_text(path); self._fb_load()

    def _fb_up(self):
        p = self.f_path.get_text().rstrip("/"); self._fb_go(os.path.dirname(p) or "/")

    def _fb_load(self):
        if self._state() != "device":
            self.f_store.clear(); self.f_status.set_text("no device connected"); return
        path = self.f_path.get_text(); self.f_status.set_text("loading " + path + " …")
        def read():
            out = adb("shell", "ls", "-laA", "--color=never", path, timeout=20)
            rows = []
            for ln in out.splitlines():
                if ln.startswith("total ") or not ln.strip(): continue
                parts = ln.split(None, 7)
                if len(parts) < 8: continue
                perms, size, name = parts[0], parts[4], parts[7]
                if name in (".", ".."): continue
                link = perms[0] == "l"
                if link and " -> " in name: name = name.split(" -> ", 1)[0]
                is_dir = perms[0] == "d" or link
                rows.append(("[dir]" if is_dir else "file", name, "" if is_dir else self._human(size), is_dir))
            rows.sort(key=lambda r: (not r[3], r[1].lower()))
            return rows
        def fill(rows):
            self.f_store.clear()
            for r in rows: self.f_store.append(list(r))
            self.f_status.set_text("%s · %d items" % (self.f_path.get_text(), len(rows)))
        self._run_async(read, fill)

    def _fb_activate(self, view, p, col):
        it = self.f_store.get_iter(p)
        if self.f_store[it][3]: self._fb_go(self.f_path.get_text().rstrip("/") + "/" + self.f_store[it][1])

    def _fb_sel(self):
        m, paths = self.f_view.get_selection().get_selected_rows()
        return [(m[p][1], m[p][3]) for p in paths]

    def _fb_transfer(self, jobs, donemsg, reload=False):
        self.f_status.set_text("transferring %d…" % len(jobs))
        state = {"ok": 0, "err": 0}; lock = threading.Lock()
        def one(job):
            op, a, b = job
            r = subprocess.run(["adb", op, a, b], capture_output=True, text=True)
            with lock:
                state["ok" if r.returncode == 0 else "err"] += 1
                GLib.idle_add(self.f_status.set_text, "transferring %d/%d…" % (state["ok"] + state["err"], len(jobs)))
        def run():
            import concurrent.futures as cf
            with cf.ThreadPoolExecutor(max_workers=6) as ex:
                list(ex.map(one, jobs))
            msg = (donemsg % state["ok"]) + (" · %d failed" % state["err"] if state["err"] else "")
            GLib.idle_add(self.f_status.set_text, msg)
            if reload: GLib.idle_add(self._fb_load)
        threading.Thread(target=run, daemon=True).start()

    def _fb_pull(self, *_):
        sel = self._fb_sel()
        if not sel: self._msg("Select items", "Pick file(s) or folder(s) to pull."); return
        d = Gtk.FileChooserDialog(title="Pull into folder", parent=self, action=Gtk.FileChooserAction.SELECT_FOLDER)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Pull", Gtk.ResponseType.OK)
        ok = d.run() == Gtk.ResponseType.OK; dst = d.get_filename(); d.destroy()
        if not ok: return
        base = self.f_path.get_text().rstrip("/")
        self._fb_transfer([("pull", base + "/" + n, dst) for n, _ in sel], "pulled %d → " + dst)

    def _fb_push(self, *_):
        if not self._need_device(): return
        d = Gtk.FileChooserDialog(title="Push file(s) here", parent=self, action=Gtk.FileChooserAction.OPEN)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Push", Gtk.ResponseType.OK); d.set_select_multiple(True)
        ok = d.run() == Gtk.ResponseType.OK; srcs = d.get_filenames(); d.destroy()
        if not ok or not srcs: return
        dst = self.f_path.get_text()
        self._fb_transfer([("push", s, dst) for s in srcs], "pushed %d here", reload=True)

    def _fb_delete(self, *_):
        sel = self._fb_sel()
        if not sel: return
        if not self._confirm("Delete %d item(s)" % len(sel), "Permanently delete on the device?"): return
        base = self.f_path.get_text().rstrip("/")
        def run():
            for n, is_dir in sel: adb("shell", "rm", "-rf" if is_dir else "-f", base + "/" + n)
            GLib.idle_add(self._fb_load); GLib.idle_add(self.f_status.set_text, "deleted %d" % len(sel))
        self._run_async(run)

    def _fb_mkdir(self, *_):
        name = self._prompt("New folder", "folder name")
        if name: self._run_async(lambda: adb("shell", "mkdir", "-p", self.f_path.get_text().rstrip("/") + "/" + name), lambda *_: self._fb_load())

    def _fb_rename(self, *_):
        sel = self._fb_sel()
        if len(sel) != 1: self._msg("Select one", "Pick a single item to rename."); return
        old = sel[0][0]; new = self._prompt("Rename", "new name", old)
        if not new or new == old: return
        base = self.f_path.get_text().rstrip("/")
        self._run_async(lambda: adb("shell", "mv", base + "/" + old, base + "/" + new), lambda *_: self._fb_load())

    def _fb_move(self, *_):
        sel = self._fb_sel()
        if not sel: return
        dst = self._prompt("Move to", "destination path on device", "/sdcard/")
        if not dst: return
        base = self.f_path.get_text().rstrip("/")
        def run():
            for n, _ in sel: adb("shell", "mv", base + "/" + n, dst)
            GLib.idle_add(self._fb_load); GLib.idle_add(self.f_status.set_text, "moved %d → %s" % (len(sel), dst))
        self._run_async(run)

